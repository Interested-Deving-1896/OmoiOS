{
  "name": "@omoios/sdk",
  "version": "0.2.0",
  "description": "OmoiOS SDK for agent workspace platform — sessions, events, multiplayer (spec §18)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "dev": "vitest",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "omoios",
    "agent",
    "workspace",
    "sdk",
    "sse",
    "websocket",
    "multiplayer"
  ],
  "author": "OmoiOS Team <team@omoios.dev>",
  "license": "Apache-2.0",
  "homepage": "https://omoios.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kivo360/OmoiOS.git",
    "directory": "sdk/typescript"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
